{
  "$id": "https://example.com/schemas/AanvragenSociaalDomein.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "title": "AanvragenSociaalDomein",
  "description": "Gehele object aanvragen sociaal domein met verschillende regelingen. Voor nu nog los opgezet, weinig verplicht om te zorgen dat de connectie goed gemaakt kan worden.",
  "additionalProperties": true,
  "required": [
    "pdf",
    "reference",
    "attachments",
    "formName",
    "sociaalDomeinRegeling",
    "zaaktypeIdentificatie"
  ],
  "properties": {
    "bsn": {
      "type": "string",
      "examples": ["999999333"],
      "description": "BSN indien ingevuld"
    },
    "csv": {
      "type": "string",
      "examples": ["https://omgeving/open-zaak/documenten/.../uuid"],
      "description": "CSV url"
    },
    "kvk": {
      "type": "string",
      "examples": ["69599084"],
      "description": "KVK indien gevuld"
    },
    "pdf": {
      "type": "string",
      "examples": ["https://omgeving/open-zaak/documenten/.../uuid"],
      "description": "PDF url"
    },
    "formName": {
      "type": "string",
      "examples": ["Contactformulier"],
      "description": "Naam van het formulier"
    },
    "bsnNamens": {
      "type": "string",
      "examples": ["999999333"],
      "description": "BSN indien handmatig gevuld namens iemand"
    },
    "kvkNamens": {
      "type": "string",
      "examples": ["69599084"],
      "description": "KVK indien handmatig gevuld namens iemand"
    },
    "reference": {
      "type": "string",
      "examples": ["OF-AB7634HJ"],
      "description": "Unieke referentie van de submission"
    },
    "aardVerzoek": {
      "type": "string",
      "examples": [],
      "description": "Aard van het verzoek (GWS)"
    },
    "attachments": {
      "type": "array",
      "items": { "type": "string" },
      "examples": [["https://.../bijlage1", "https://.../bijlage2"]],
      "description": "Lijst van bijlage-urls"
    },
    "inlogmiddel": {
      "type": "string",
      "examples": ["digid"],
      "description": "eherkenning of digid"
    },
    "networkShare": {
      "type": "string",
      "examples": [
        "//karelstad/data/gemeenschappelijk/Webformulieren/Accp/TDL"
      ],
      "description": "De hoofdmap op de netwerkschijf waar een map aangemaakt moet worden en de bestanden naartoe geschreven worden"
    },
    "datumAanvraag": {
      "type": "string",
      "examples": ["2025-07-29"],
      "description": "Datum van aanvraag"
    },
    "datumStartAanvraag": {
      "type": "string",
      "examples": ["2025-08-01"],
      "description": "Startdatum van de aanvraag. Wanneer heeft iemand voor het eerst het formulier geopend zonder af te maken? Format nog onbekend."
    },
    "bsnOrKvkToFile": {
      "type": "boolean",
      "examples": [true, false],
      "description": "Indicates if the bsn / kvk field should be saved to a separate text file."
    },
    "indBestaandeKlant": {
      "type": "string",
      "examples": ["JA"],
      "description": "Indicatie bestaande klant (ja/nee). Voor nu nog niet bedacht wat het format moet zijn."
    },
    "sociaalDomeinRegeling": {
      "type": "string",
      "examples": ["BIJSTAND", "BBZ", "IIT"],
      "description": "Naam van de regeling die aangevraagd wordt"
    },
    "zaaktypeIdentificatie": {
      "type": "string",
      "examples": ["BIJSTAND-AANVRAAG", "INDIVIDUELE-INKOMENSTOESLAG"],
      "description": "Identificatie van het zaaktype in open-zaak"
    },
    "monitoringNetworkShare": {
      "type": "string",
      "examples": [
        "/karelstad/data/gemeenschappelijk/Webformulieren/Accp/TDL/Monitoring"
      ],
      "description": "Optionele locatie voor monitoring. Indien deze waarde gevuld is, wordt de aanvraag met bijlagen ook in deze map geplaatst."
    },
    "internalNotificationEmails": {
      "type": "array",
      "items": { "type": "string", "format": "email" },
      "default": [],
      "examples": [["ops-team@example.com", "support@example.com"]],
      "description": "E-mail addresses of internal employees or departments to notify when a new submission arrives."
    },

    "client": {
      "type": "object",
      "description": "Gegevens van de klant/burger opgezet volgens het GWS webintake format. Uiteindelijk zijn achternaam, geslacht en geboortedatum verplicht. Nog niet in dit object.",
      "properties": {
        "relatie": {
          "type": "object",
          "description": "Optioneel relatie-object voor de cliënt",
          "properties": {
            "Begindatum": {
              "type": "string",
              "format": "date",
              "examples": ["2025-01-01"],
              "description": "Startdatum van de relatie (YYYY-MM-DD)"
            },
            "SoortRelatie": {
              "type": "string",
              "examples": ["PARTNER"],
              "description": "Type relatie (bijv. partner, kind, ouder)"
            },
            "CdFictieveBegindat": {
              "type": "string",
              "examples": ["99999999"],
              "description": "Code voor fictieve begindatum indien geen echte bekend is"
            },
            "Partner": {
              "type": "object",
              "description": "Gegevens van de partner in de relatie",
              "properties": {
                "Iban": {
                  "type": "string",
                  "examples": ["NL12ABCD0123456789"],
                  "description": "IBAN van partner"
                },
                "Geslacht": {
                  "type": "string",
                  "examples": ["V"],
                  "description": "Geslacht partner"
                },
                "Voornamen": {
                  "type": "string",
                  "examples": ["Anna Maria"],
                  "description": "Volledige voornamen"
                },
                "Achternaam": {
                  "type": "string",
                  "examples": ["Jong"],
                  "description": "Achternaam partner"
                },
                "Telefoonnr": {
                  "type": "object",
                  "description": "Telefoonnummer partner",
                  "properties": {
                    "Netnr": { "type": "string", "examples": ["024"] },
                    "Abonneenr": { "type": "string", "examples": ["1234567"] },
                    "TypeTelefoonnr": {
                      "type": "string",
                      "examples": ["MOBIEL"]
                    }
                  }
                },
                "Voorletters": {
                  "type": "string",
                  "examples": ["A.M."],
                  "description": "Initialen partner"
                },
                "Voorvoegsel": {
                  "type": "string",
                  "examples": ["de"],
                  "description": "Voorvoegsel achternaam partner"
                },
                "Geboortedatum": {
                  "type": "string",
                  "format": "date",
                  "examples": ["1983-11-20"],
                  "description": "Geboortedatum partner (YYYY-MM-DD)"
                },
                "Nationaliteit": {
                  "type": "object",
                  "description": "Nationaliteit van de partner",
                  "properties": {
                    "CdNationaliteit": {
                      "type": "string",
                      "examples": ["NL"],
                      "description": "NL-code nationaliteit"
                    }
                  }
                },
                "Feitelijkadres": {
                  "type": "object",
                  "description": "Feitelijk verblijfadres",
                  "properties": {
                    "Postcode": { "type": "string", "examples": ["1234AB"] },
                    "Straatnaam": {
                      "type": "string",
                      "examples": ["Hoofdstraat"]
                    },
                    "Woonplaatsnaam": {
                      "type": "string",
                      "examples": ["Nijmegen"]
                    }
                  }
                },
                "BurgerServiceNr": {
                  "type": "string",
                  "examples": ["123456788"],
                  "description": "BSN van partner"
                },
                "EMailAdresClient": {
                  "type": "string",
                  "format": "email",
                  "examples": ["partner@example.com"],
                  "description": "Emailadres partner"
                },
                "Correspondentieadres": {
                  "type": "object",
                  "description": "Adres voor correspondentie",
                  "properties": {
                    "Postcode": { "type": "string", "examples": ["1234AB"] },
                    "Huisnummer": { "type": "string", "examples": ["12"] },
                    "Straatnaam": {
                      "type": "string",
                      "examples": ["Hoofdstraat"]
                    },
                    "Gemeentenaam": {
                      "type": "string",
                      "examples": ["Nijmegen"]
                    },
                    "Woonplaatsnaam": {
                      "type": "string",
                      "examples": ["Nijmegen"]
                    }
                  }
                },
                "AanduidingNaamgebruik": {
                  "type": "string",
                  "examples": ["Mevrouw"],
                  "description": "Naamgebruik aanduiding partner"
                },
                "CdFictieveGeboortedat": {
                  "type": "string",
                  "examples": ["99999999"],
                  "description": "Fictieve geboortedatumcode partner"
                }
              }
            }
          }
        },

        "Iban": { "type": "string", "examples": ["NL12ABCD0123456789"] },
        "Geslacht": {
          "type": "string",
          "examples": ["M"],
          "description": "Geslacht"
        },
        "Voornamen": {
          "type": "string",
          "examples": ["NaamEen NaamTwee"],
          "description": "Volledige voornamen"
        },
        "Achternaam": {
          "type": "string",
          "examples": ["Dijk"],
          "description": "Achternaam klant"
        },
        "Telefoonnr": {
          "type": "object",
          "description": "Telefoonnummer",
          "properties": {
            "Netnr": { "type": "string", "examples": ["024"] },
            "Abonneenr": { "type": "string", "examples": ["1234567"] },
            "TypeTelefoonnr": { "type": "string", "examples": ["MOBIEL"] }
          }
        },
        "Voorletters": {
          "type": "string",
          "examples": ["V.L."],
          "description": "Initialen"
        },
        "Voorvoegsel": {
          "type": "string",
          "examples": ["van"],
          "description": "Voorvoegsel achternaam"
        },
        "Geboortedatum": {
          "type": "string",
          "format": "date",
          "examples": ["1980-05-15"],
          "description": "Geboortedatum (YYYY-MM-DD)"
        },
        "Nationaliteit": {
          "type": "object",
          "description": "Nationaliteit",
          "properties": {
            "CdNationaliteit": { "type": "string", "examples": ["NL"] }
          }
        },
        "Feitelijkadres": {
          "type": "object",
          "description": "Feitelijk adres",
          "properties": {
            "Locatie": { "type": "string" },
            "Postcode": { "type": "string" },
            "Huisnummer": { "type": "string" },
            "Straatnaam": { "type": "string" },
            "Gemeentenaam": { "type": "string" },
            "Woonplaatsnaam": { "type": "string" }
          }
        },
        "BurgerServiceNr": {
          "type": "string",
          "examples": ["123456789"],
          "description": "BRP Burgerservicenummer"
        },
        "EMailAdresClient": {
          "type": "string",
          "format": "email",
          "examples": ["naam@example.com"],
          "description": "Emailadres van de cliënt"
        },
        "Correspondentieadres": {
          "type": "object",
          "description": "Correspondentieadres",
          "properties": {
            "Locatie": { "type": "string", "examples": ["Thuis"] },
            "Postcode": { "type": "string", "examples": ["1234AB"] },
            "Huisletter": { "type": "string", "examples": ["A"] },
            "Huisnummer": { "type": "string", "examples": ["10"] },
            "Straatnaam": { "type": "string", "examples": ["Hoofdstraat"] },
            "Gemeentenaam": { "type": "string", "examples": ["Nijmegen"] },
            "Woonplaatsnaam": { "type": "string", "examples": ["Nijmegen"] },
            "HuisnrToevoeging": { "type": "string", "examples": ["bis"] }
          }
        },
        "AanduidingNaamgebruik": {
          "type": "string",
          "examples": ["Meneer"],
          "description": "Naamgebruik aanduiding"
        },
        "CdFictieveGeboortedat": {
          "type": "string",
          "examples": ["99999999"],
          "description": "Fictieve geboortedatumcode"
        }
      }
    },

    "aanvragerGegevens": {
      "type": "object",
      "description": "Extra gegevens van de aanvrager om extra datachecks te kunnen doen.",
      "properties": {
        "rni": {
          "type": "string",
          "examples": [""],
          "description": "Extra data rni check om data compleet te maken. Voor nu even open gehouden"
        },
        "email": {
          "type": "string",
          "examples": ["test@example.com"],
          "description": "E-mailadres voor contact"
        },
        "leeftijd": {
          "type": "string",
          "examples": ["27"],
          "description": "Leeftijd volgens Haal Centraal"
        },
        "bewindvoering": {
          "type": "boolean",
          "examples": [false],
          "description": "In verband met correspondentie."
        },
        "geboorteDatum": {
          "type": "string",
          "examples": ["01-01-1980"],
          "description": "Optionele geboortedatum"
        },
        "volledigeNaam": {
          "type": "string",
          "examples": ["Voornaam tussenvoegsel Achternaam"],
          "description": "Volledige naam om aan te kunnen spreken"
        },
        "telefoonnummer": {
          "type": "string",
          "examples": ["0612345678"],
          "description": "Telefoonnummer voor contact"
        },
        "geboorteDatumNietStandaard": {
          "type": "boolean",
          "examples": [false],
          "description": "In uitzonderlijke gevallen kan een geboortedatum data missen. In dat geval zal er een extra check gedaan moeten worden."
        },

        "adres": {
          "type": "object",
          "description": "Adresgegevens van de aanvrager. Alle velden optioneel om maximale flexibiliteit te bieden.",
          "additionalProperties": true,
          "properties": {
            "straatnaam": {
              "type": "string",
              "examples": ["Hoofdstraat"],
              "description": "Naam van de straat"
            },
            "huisnummerVolledig": {
              "type": "string",
              "examples": ["12A bis"],
              "description": "Huisnummer inclusief huisletter en toevoeging als één string"
            },
            "huisnummer": {
              "anyOf": [{ "type": "string" }, { "type": "number" }],
              "examples": [12, "12"],
              "description": "Huisnummer als getal of string"
            },
            "huisletter": {
              "type": "string",
              "examples": ["A"],
              "description": "Huisletter achter het huisnummer"
            },
            "huisnummertoevoeging": {
              "type": "string",
              "examples": ["bis"],
              "description": "Toevoeging achter huisnummer en huisletter"
            },
            "postcode": {
              "type": "string",
              "examples": ["1234AB"],
              "description": "Postcode in Nederlands formaat"
            },
            "woonplaats": {
              "type": "string",
              "examples": ["Nijmegen"],
              "description": "Naam van de woonplaats"
            },
            "gemeente": {
              "type": "string",
              "examples": ["Nijmegen"],
              "description": "Naam van de gemeente"
            },
            "postbus": {
              "anyOf": [{ "type": "string" }, { "type": "number" }],
              "examples": [1234, "1234"],
              "description": "Postbusnummer als getal of string"
            }
          }
        },

        "bewijzen": {
          "anyOf": [
            { "type": "null" },
            { "type": "object", "additionalProperties": true },
            { "type": "array", "items": {} }
          ],
          "description": "Flexibel object voor bewijzen bij de aanvraag. Kan een object met named arrays, een losse array, null of volledig leeg zijn."
        },

        "cosigner": {
          "type": "object",
          "description": "Gegevens van de mede-ondertekenaar (meestal partner, maar kan ook anderen zijn).",
          "additionalProperties": true,
          "properties": {
            "cosign_data": {
              "anyOf": [
                { "type": "object", "additionalProperties": true },
                { "type": "null" }
              ],
              "description": "Co-sign data object (nog te configureren)"
            },
            "cosign_date": {
              "type": ["string", "null"],
              "format": "date-time",
              "examples": ["2025-07-29T10:00:00Z", null],
              "description": "Datum en tijd van ondertekening"
            },
            "cosign_bsn": {
              "type": ["string", "null"],
              "examples": ["123456789", null],
              "description": "BSN van de mede-ondertekenaar"
            },
            "cosign_kvk": {
              "type": ["string", "null"],
              "examples": ["69599084", null],
              "description": "KVK-nummer van de mede-ondertekenaar"
            },
            "cosign_pseudo": {
              "type": ["string", "null"],
              "examples": ["pseudo-abc123", null],
              "description": "Pseudoniem of geanonimiseerde identificatie van de mede-ondertekenaar"
            },
            "cosignType": {
              "type": ["string", "null"],
              "examples": ["PARTNER", null],
              "description": "Type mede-ondertekenaar (bijv. PARTNER, OUDER, VOOGD)"
            },
            "volledigeNaam": {
              "type": "string",
              "examples": ["Anna de Jong"],
              "description": "Volledige naam van de mede-ondertekenaar"
            },
            "voornaam": {
              "type": "string",
              "examples": ["Anna"],
              "description": "Voornaam van de mede-ondertekenaar"
            },
            "tussenvoegsel": {
              "type": "string",
              "examples": ["de"],
              "description": "Tussenvoegsel achternaam"
            },
            "achternaam": {
              "type": "string",
              "examples": ["Jong"],
              "description": "Achternaam van de mede-ondertekenaar"
            },
            "initialen": {
              "type": "string",
              "examples": ["A.M."],
              "description": "Initialen van de mede-ondertekenaar"
            },
            "geboorteDatum": {
              "type": "string",
              "format": "date",
              "examples": ["1983-11-20"],
              "description": "Geboortedatum (YYYY-MM-DD)"
            },
            "email": {
              "type": "string",
              "format": "email",
              "examples": ["cosigner@example.com"],
              "description": "E-mailadres van de mede-ondertekenaar"
            },
            "telefoonnummer": {
              "type": "string",
              "examples": ["0612345678"],
              "description": "Telefoonnummer van de mede-ondertekenaar"
            }
          }
        }
      }
    }
  }
}
